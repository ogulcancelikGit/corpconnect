// ============================================================
// CorpConnect - Prisma Schema
// Database: MySQL 8.0
// ORM: Prisma 5.22
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUM TANIMLAMALARI
// ============================================================

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum NotificationType {
  NEWS
  POLL
  MESSAGE
  SYSTEM
  LEAVE
  TASK
  EXPENSE
  SUGGESTION
  CELEBRATION
  MENTION
  TRAINING
  CALENDAR
}

enum SuggestionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum SuggestionCategory {
  PROCESS
  TECHNOLOGY
  CULTURE
  SAFETY
  OTHER
}

enum EventType {
  MEETING
  DEADLINE
  HOLIDAY
  REMINDER
  OTHER
}

enum AttendeeStatus {
  PENDING
  GOING
  MAYBE
  DECLINED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseCategory {
  TRAVEL
  FOOD
  ACCOMMODATION
  OFFICE
  OTHER
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  EXCUSE
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ============================================================
// KULLANICI & KİMLİK
// ============================================================

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique @db.VarChar(255)
  password       String    @db.VarChar(255)
  firstName      String    @db.VarChar(100)
  lastName       String    @db.VarChar(100)
  role           Role      @default(EMPLOYEE)
  isActive       Boolean   @default(true)
  emailVerified  Boolean   @default(false)
  lastLoginAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  profile              UserProfile?
  refreshTokens        RefreshToken[]
  passwordResets       PasswordReset[]
  news                 News[]
  polls                Poll[]
  pollVotes            PollVote[]
  trainings            Training[]
  files                File[]
  createdConversations Conversation[]
  conversationMembers  ConversationMember[]
  sentMessages         Message[]
  notifications        Notification[]
  notificationPreferences NotificationPreference[]
  leaveRequests        LeaveRequest[]       @relation("UserLeaves")
  reviewedLeaves       LeaveRequest[]       @relation("ReviewedLeaves")
  activityLogs         ActivityLog[]
  createdTasks         Task[]               @relation("CreatedTasks")
  assignedTasks        Task[]               @relation("AssignedTasks")
  expenses             Expense[]            @relation("UserExpenses")
  reviewedExpenses     Expense[]            @relation("ReviewedExpenses")
  createdEvents        CalendarEvent[]      @relation("CreatedEvents")
  eventAttendees       EventAttendee[]
  suggestions          Suggestion[]
  messageReactions     MessageReaction[]
  pinnedMessages       Message[]         @relation("PinnedMessages")
  newsViews            NewsView[]
  trainingViews        TrainingView[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model UserProfile {
  userId     Int       @id
  avatar     String?   @db.VarChar(500)
  phone      String?   @db.VarChar(20)
  department String?   @db.VarChar(100)
  position   String?   @db.VarChar(100)
  bio        String?   @db.VarChar(500)
  birthDate  DateTime?
  hireDate   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique @db.VarChar(500)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique @db.VarChar(500)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

// ============================================================
// İÇERİK MODÜLLERİ
// ============================================================

model News {
  id        Int       @id @default(autoincrement())
  authorId  Int
  title     String    @db.VarChar(255)
  content   String    @db.Text
  category  String?   @db.VarChar(100)
  isPinned  Boolean   @default(false)
  viewCount Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views  NewsView[]

  @@index([authorId])
  @@index([isPinned, createdAt])
  @@index([category])
  @@map("news")
}

model NewsView {
  id       Int      @id @default(autoincrement())
  userId   Int
  newsId   Int
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([userId, newsId])
  @@index([newsId])
  @@map("news_views")
}

model Poll {
  id         Int       @id @default(autoincrement())
  authorId   Int
  question   String    @db.VarChar(500)
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean   @default(true)
  totalVotes Int       @default(0)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  author  User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([authorId])
  @@index([isActive, endDate])
  @@map("polls")
}

model PollOption {
  id         Int    @id @default(autoincrement())
  pollId     Int
  optionText String @db.VarChar(255)
  voteCount  Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        Int      @id @default(autoincrement())
  pollId    Int
  optionId  Int
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

model Training {
  id          Int       @id @default(autoincrement())
  authorId    Int
  title       String    @db.VarChar(255)
  description String?   @db.Text
  videoUrl    String?   @db.VarChar(500)
  fileUrl     String?   @db.VarChar(500)
  category    String?   @db.VarChar(100)
  duration    Int?
  viewCount   Int       @default(0)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  files  TrainingFile[]
  views  TrainingView[]

  @@index([authorId])
  @@index([category])
  @@map("trainings")
}

model TrainingView {
  id         Int      @id @default(autoincrement())
  userId     Int
  trainingId Int
  viewedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingId])
  @@index([trainingId])
  @@map("training_views")
}

// ============================================================
// DOSYA YÖNETİMİ
// ============================================================

model File {
  id           Int       @id @default(autoincrement())
  originalName String    @db.VarChar(255)
  storedName   String    @db.VarChar(255)
  mimeType     String    @db.VarChar(100)
  fileSize     Int
  filePath     String    @db.VarChar(500)
  uploadedBy   Int
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  uploader      User           @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  trainingFiles TrainingFile[]
  messageFiles  MessageFile[]

  @@index([uploadedBy])
  @@map("files")
}

model TrainingFile {
  id         Int @id @default(autoincrement())
  trainingId Int
  fileId     Int

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  file     File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([trainingId, fileId])
  @@index([trainingId])
  @@map("training_files")
}

// ============================================================
// MESAJLAŞMA
// ============================================================

model Conversation {
  id            Int              @id @default(autoincrement())
  createdBy     Int
  type          ConversationType
  name          String?          @db.VarChar(100)
  avatar        String?          @db.VarChar(500)
  lastMessageAt DateTime?
  archivedAt    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  creator User                 @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  members ConversationMember[]
  messages Message[]

  @@index([createdBy])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id             Int        @id @default(autoincrement())
  conversationId Int
  userId         Int
  role           MemberRole @default(MEMBER)
  lastReadAt     DateTime?
  joinedAt       DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id              Int           @id @default(autoincrement())
  conversationId  Int
  senderId        Int
  replyToId       Int?
  forwardedFromId Int?
  content         String?       @db.Text
  status          MessageStatus @default(SENT)
  isEdited        Boolean       @default(false)
  pinnedAt        DateTime?
  pinnedBy        Int?
  readAt          DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo        Message?          @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]         @relation("MessageReply")
  forwardedFrom  Message?          @relation("ForwardedMessages", fields: [forwardedFromId], references: [id])
  forwardedMsgs  Message[]         @relation("ForwardedMessages")
  pinnedByUser   User?             @relation("PinnedMessages", fields: [pinnedBy], references: [id])
  files          MessageFile[]
  reactions      MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToId])
  @@index([pinnedAt])
  @@map("messages")
}

model MessageFile {
  id        Int @id @default(autoincrement())
  messageId Int
  fileId    Int

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([messageId, fileId])
  @@index([messageId])
  @@map("message_files")
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String   @db.VarChar(10)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// ============================================================
// BİLDİRİM & SİSTEM
// ============================================================

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String           @db.VarChar(255)
  body      String           @db.VarChar(500)
  type      NotificationType
  link      String?          @db.VarChar(500)
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id      Int              @id @default(autoincrement())
  userId  Int
  type    NotificationType
  enabled Boolean          @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}

// ============================================================
// AKTİVİTE LOGLARI
// ============================================================

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String   @db.VarChar(100)
  entity    String?  @db.VarChar(100)
  entityId  Int?
  detail    String?  @db.VarChar(500)
  ip        String?  @db.VarChar(50)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================
// İZİN YÖNETİMİ
// ============================================================

model LeaveRequest {
  id         Int         @id @default(autoincrement())
  userId     Int
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  days       Int
  reason     String?     @db.VarChar(500)
  status     LeaveStatus @default(PENDING)
  reviewedBy Int?
  reviewNote String?     @db.VarChar(500)
  reviewedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user     User  @relation("UserLeaves", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedLeaves", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// ============================================================
// GÖREV YÖNETİMİ
// ============================================================

model Task {
  id          Int          @id @default(autoincrement())
  title       String       @db.VarChar(255)
  description String?      @db.Text
  priority    TaskPriority @default(NORMAL)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  createdBy   Int
  assignedTo  Int?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  creator  User  @relation("CreatedTasks", fields: [createdBy], references: [id], onDelete: Cascade)
  assignee User? @relation("AssignedTasks", fields: [assignedTo], references: [id])

  @@index([createdBy])
  @@index([assignedTo])
  @@index([status])
  @@map("tasks")
}

// ============================================================
// MASRAF YÖNETİMİ
// ============================================================

model Expense {
  id          Int             @id @default(autoincrement())
  userId      Int
  title       String          @db.VarChar(255)
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("TRY") @db.VarChar(10)
  category    ExpenseCategory
  description String?         @db.VarChar(500)
  receiptUrl  String?         @db.VarChar(500)
  status      ExpenseStatus   @default(PENDING)
  reviewedBy  Int?
  reviewNote  String?         @db.VarChar(500)
  reviewedAt  DateTime?
  expenseDate DateTime
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User  @relation("UserExpenses", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedExpenses", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([expenseDate])
  @@map("expenses")
}

// ============================================================
// TAKVİM
// ============================================================

model CalendarEvent {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String?   @db.Text
  type        EventType @default(OTHER)
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean   @default(false)
  location    String?   @db.VarChar(255)
  isPublic    Boolean   @default(true)
  createdBy   Int
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator   User            @relation("CreatedEvents", fields: [createdBy], references: [id], onDelete: Cascade)
  attendees EventAttendee[]

  @@index([createdBy])
  @@index([startDate, endDate])
  @@map("calendar_events")
}

model EventAttendee {
  id          Int            @id @default(autoincrement())
  eventId     Int
  userId      Int
  status      AttendeeStatus @default(PENDING)
  respondedAt DateTime?

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_attendees")
}

// ============================================================
// ÖNERİ SİSTEMİ
// ============================================================

model Suggestion {
  id          Int                @id @default(autoincrement())
  userId      Int
  title       String             @db.VarChar(255)
  content     String             @db.Text
  category    SuggestionCategory @default(OTHER)
  status      SuggestionStatus   @default(PENDING)
  adminNote   String?            @db.VarChar(500)
  reviewedBy  Int?
  reviewedAt  DateTime?
  isAnonymous Boolean            @default(false)
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([category])
  @@map("suggestions")
}

model SystemSettings {
  id           Int      @id @default(autoincrement())
  settingKey   String   @unique @db.VarChar(100)
  settingValue String   @db.Text
  updatedAt    DateTime @updatedAt

  @@index([settingKey])
  @@map("system_settings")
}
