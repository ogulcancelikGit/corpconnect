# Veritabanı bağlantısı — kendi MySQL kullanıcı/şifrenizle doldurun
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/corpconnect"

# JWT secret'ları — her biri için GÜÇLÜ ve BİRBİRİNDEN FARKLI rastgele değer üretin.
# Örnek üretim:  openssl rand -hex 32   (Windows PowerShell: aşağıdaki komut)
#   [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Max 256 }))
# Bu placeholder'ları GERÇEK bir değerle değiştirmeden kullanmayın.
JWT_SECRET="buraya-uretilmis-guvenli-rastgele-deger"
JWT_REFRESH_SECRET="buraya-FARKLI-uretilmis-guvenli-rastgele-deger"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"
UPLOAD_PATH="uploads"
MAX_FILE_SIZE=10485760

# --- Mail (SMTP) — şifre sıfırlama mailleri için ---
# Mailtrap sandbox örneği. Gmail için: host=smtp.gmail.com, port=587, user=mailin, pass=uygulama şifresi
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CorpConnect <no-reply@corpconnect.local>"
